<section
  class="rl-hero rl-hero--{{ section.settings.background_style }} rl-hero--content-{{ section.settings.content_alignment }}"
  style="
    --hero-height-desktop: {{ section.settings.height_desktop }}px;
    --hero-height-mobile: {{ section.settings.height_mobile }}px;
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --hero-text-max: {{ section.settings.text_max_width }}px;
  "
>
  <div class="rl-hero__media">
    <div class="rl-hero__poster-stage">
      {% liquid
        assign card_1_label = section.settings.card_1_alt_text
        if card_1_label == blank
          assign card_1_label = section.settings.card_1_image.alt
        endif
        if card_1_label == blank
          assign card_1_label = 'Render-Lab hero card 1'
        endif

        assign card_2_label = section.settings.card_2_alt_text
        if card_2_label == blank
          assign card_2_label = section.settings.card_2_image.alt
        endif
        if card_2_label == blank
          assign card_2_label = 'Render-Lab hero card 2'
        endif

        assign card_3_label = section.settings.card_3_alt_text
        if card_3_label == blank
          assign card_3_label = section.settings.card_3_image.alt
        endif
        if card_3_label == blank
          assign card_3_label = 'Render-Lab hero card 3'
        endif
      %}
      {% if section.settings.card_1_link != blank %}
        <a class="rl-hero-card rl-hero-card--1" href="{{ section.settings.card_1_link }}" aria-label="{{ card_1_label | escape }}">
          {% if section.settings.card_1_image %}
            {{ section.settings.card_1_image | image_url: width: 900 | image_tag: loading: 'eager', sizes: '(min-width: 990px) 28vw, 42vw', alt: card_1_label, class: 'rl-hero-card__image' }}
          {% else %}
            <span class="rl-hero-card__placeholder"></span>
          {% endif %}
        </a>
      {% else %}
        <div class="rl-hero-card rl-hero-card--1">
          {% if section.settings.card_1_image %}
            {{ section.settings.card_1_image | image_url: width: 900 | image_tag: loading: 'eager', sizes: '(min-width: 990px) 28vw, 42vw', alt: card_1_label, class: 'rl-hero-card__image' }}
          {% else %}
            <span class="rl-hero-card__placeholder"></span>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.card_2_link != blank %}
        <a class="rl-hero-card rl-hero-card--2" href="{{ section.settings.card_2_link }}" aria-label="{{ card_2_label | escape }}">
          {% if section.settings.card_2_image %}
            {{ section.settings.card_2_image | image_url: width: 900 | image_tag: loading: 'eager', sizes: '(min-width: 990px) 28vw, 42vw', alt: card_2_label, class: 'rl-hero-card__image' }}
          {% else %}
            <span class="rl-hero-card__placeholder"></span>
          {% endif %}
        </a>
      {% else %}
        <div class="rl-hero-card rl-hero-card--2">
          {% if section.settings.card_2_image %}
            {{ section.settings.card_2_image | image_url: width: 900 | image_tag: loading: 'eager', sizes: '(min-width: 990px) 28vw, 42vw', alt: card_2_label, class: 'rl-hero-card__image' }}
          {% else %}
            <span class="rl-hero-card__placeholder"></span>
          {% endif %}
        </div>
      {% endif %}

      {% if section.settings.card_3_link != blank %}
        <a class="rl-hero-card rl-hero-card--3" href="{{ section.settings.card_3_link }}" aria-label="{{ card_3_label | escape }}">
          {% if section.settings.card_3_image %}
            {{ section.settings.card_3_image | image_url: width: 900 | image_tag: loading: 'eager', sizes: '(min-width: 990px) 28vw, 42vw', alt: card_3_label, class: 'rl-hero-card__image' }}
          {% else %}
            <span class="rl-hero-card__placeholder"></span>
          {% endif %}
        </a>
      {% else %}
        <div class="rl-hero-card rl-hero-card--3">
          {% if section.settings.card_3_image %}
            {{ section.settings.card_3_image | image_url: width: 900 | image_tag: loading: 'eager', sizes: '(min-width: 990px) 28vw, 42vw', alt: card_3_label, class: 'rl-hero-card__image' }}
          {% else %}
            <span class="rl-hero-card__placeholder"></span>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
  <div class="rl-hero__overlay"></div>
  <div class="rl-hero__content rl-page-width">
    <p class="rl-eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.text }}</p>
    <div class="rl-hero__actions">
      <a class="rl-button" href="{{ section.settings.primary_url }}">{{ section.settings.primary_label }}</a>
      {% if section.settings.show_secondary_button %}
        <a class="rl-button rl-button--accent" href="{{ section.settings.secondary_url }}">{{ section.settings.secondary_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Render-Lab hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Premium metal art marketplace" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Wall art that hits different" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Curated creator drops, sharp metal finishes, and bold artwork made for rooms that deserve more than blank walls." },
    { "type": "text", "id": "primary_label", "label": "Primary label", "default": "Shop now" },
    { "type": "url", "id": "primary_url", "label": "Primary link" },
    { "type": "checkbox", "id": "show_secondary_button", "label": "Show secondary button", "default": true },
    { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "Limited drops" },
    { "type": "url", "id": "secondary_url", "label": "Secondary link" },
    { "type": "header", "content": "Hero card 1" },
    { "type": "image_picker", "id": "card_1_image", "label": "Hero card 1 image" },
    { "type": "text", "id": "card_1_alt_text", "label": "Hero card 1 alt text" },
    { "type": "url", "id": "card_1_link", "label": "Hero card 1 link" },
    { "type": "header", "content": "Hero card 2" },
    { "type": "image_picker", "id": "card_2_image", "label": "Hero card 2 image" },
    { "type": "text", "id": "card_2_alt_text", "label": "Hero card 2 alt text" },
    { "type": "url", "id": "card_2_link", "label": "Hero card 2 link" },
    { "type": "header", "content": "Hero card 3" },
    { "type": "image_picker", "id": "card_3_image", "label": "Hero card 3 image" },
    { "type": "text", "id": "card_3_alt_text", "label": "Hero card 3 alt text" },
    { "type": "url", "id": "card_3_link", "label": "Hero card 3 link" },
    { "type": "range", "id": "height_desktop", "label": "Hero height desktop", "min": 520, "max": 920, "step": 20, "unit": "px", "default": 760 },
    { "type": "range", "id": "height_mobile", "label": "Hero height mobile", "min": 560, "max": 860, "step": 20, "unit": "px", "default": 680 },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 20, "max": 90, "step": 5, "unit": "%", "default": 65 },
    {
      "type": "select",
      "id": "background_style",
      "label": "Background style",
      "options": [
        { "value": "cinematic", "label": "Cinematic" },
        { "value": "ember", "label": "Ember" },
        { "value": "clean", "label": "Clean dark" }
      ],
      "default": "cinematic"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    { "type": "range", "id": "text_max_width", "label": "Text max width", "min": 480, "max": 900, "step": 20, "unit": "px", "default": 760 }
  ],
  "presets": [
    { "name": "Render-Lab hero" }
  ]
}
{% endschema %}
