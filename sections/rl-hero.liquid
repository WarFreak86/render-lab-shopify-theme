<section
  class="rl-hero rl-hero--{{ section.settings.background_style }} rl-hero--content-{{ section.settings.content_alignment }}"
  style="
    --hero-height-desktop: {{ section.settings.height_desktop }}px;
    --hero-height-mobile: {{ section.settings.height_mobile }}px;
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --hero-text-max: {{ section.settings.text_max_width }}px;
  "
>
  <div class="rl-hero__media">
    {% if section.blocks.size > 0 %}
      <div class="rl-hero__poster-stage">
        {% for block in section.blocks %}
          {% liquid
            assign card_label = block.settings.alt_text
            if card_label == blank
              assign card_label = block.settings.image.alt
            endif
            if card_label == blank
              assign card_label = 'Render-Lab poster card'
            endif
          %}
          {% capture card_style %}
            --rotation: {{ block.settings.rotation }}deg;
            --offset-y: {{ block.settings.vertical_offset }}px;
            --card-width: {{ block.settings.card_width }}px;
          {% endcapture %}
          {% if block.settings.link != blank %}
            <a
              class="rl-hero-card rl-hero-card--{{ forloop.index }}"
              href="{{ block.settings.link }}"
              style="{{ card_style | strip }}"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.image %}
                {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'eager', sizes: '(min-width: 990px) 28vw, 42vw', alt: card_label, class: 'rl-hero-card__image' }}
              {% else %}
                <span class="rl-hero-card__placeholder"></span>
              {% endif %}
            </a>
          {% else %}
            <div
              class="rl-hero-card rl-hero-card--{{ forloop.index }}"
              style="{{ card_style | strip }}"
              {{ block.shopify_attributes }}
            >
              {% if block.settings.image %}
                {{ block.settings.image | image_url: width: 900 | image_tag: loading: 'eager', sizes: '(min-width: 990px) 28vw, 42vw', alt: card_label, class: 'rl-hero-card__image' }}
              {% else %}
                <span class="rl-hero-card__placeholder"></span>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="rl-hero__poster-stage">
        {% for i in (1..4) %}
          <div class="rl-hero-card rl-hero-card--{{ i }}">
            <span class="rl-hero-card__placeholder"></span>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
  <div class="rl-hero__overlay"></div>
  <div class="rl-hero__content rl-page-width">
    <p class="rl-eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.text }}</p>
    <div class="rl-hero__actions">
      <a class="rl-button" href="{{ section.settings.primary_url }}">{{ section.settings.primary_label }}</a>
      {% if section.settings.show_secondary_button %}
        <a class="rl-button rl-button--accent" href="{{ section.settings.secondary_url }}">{{ section.settings.secondary_label }}</a>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Render-Lab hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Premium metal art marketplace" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Wall art that hits different" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Curated creator drops, sharp metal finishes, and bold artwork made for rooms that deserve more than blank walls." },
    { "type": "text", "id": "primary_label", "label": "Primary label", "default": "Shop now" },
    { "type": "url", "id": "primary_url", "label": "Primary link" },
    { "type": "checkbox", "id": "show_secondary_button", "label": "Show secondary button", "default": true },
    { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "Limited drops" },
    { "type": "url", "id": "secondary_url", "label": "Secondary link" },
    { "type": "range", "id": "height_desktop", "label": "Hero height desktop", "min": 520, "max": 920, "step": 20, "unit": "px", "default": 760 },
    { "type": "range", "id": "height_mobile", "label": "Hero height mobile", "min": 560, "max": 860, "step": 20, "unit": "px", "default": 680 },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 20, "max": 90, "step": 5, "unit": "%", "default": 65 },
    {
      "type": "select",
      "id": "background_style",
      "label": "Background style",
      "options": [
        { "value": "cinematic", "label": "Cinematic" },
        { "value": "ember", "label": "Ember" },
        { "value": "clean", "label": "Clean dark" }
      ],
      "default": "cinematic"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    { "type": "range", "id": "text_max_width", "label": "Text max width", "min": 480, "max": 900, "step": 20, "unit": "px", "default": 760 }
  ],
  "blocks": [
    {
      "type": "poster_card",
      "name": "Poster card",
      "limit": 4,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Card image" },
        { "type": "text", "id": "alt_text", "label": "Alt text" },
        { "type": "url", "id": "link", "label": "Card link" },
        { "type": "range", "id": "rotation", "label": "Rotation", "min": -12, "max": 12, "step": 1, "unit": "deg", "default": 0 },
        { "type": "range", "id": "vertical_offset", "label": "Vertical offset", "min": -120, "max": 120, "step": 8, "unit": "px", "default": 0 },
        { "type": "range", "id": "card_width", "label": "Card width", "min": 180, "max": 420, "step": 10, "unit": "px", "default": 300 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Render-Lab hero",
      "blocks": [
        { "type": "poster_card", "settings": { "rotation": -6, "vertical_offset": 32, "card_width": 300 } },
        { "type": "poster_card", "settings": { "rotation": 3, "vertical_offset": -42, "card_width": 330 } },
        { "type": "poster_card", "settings": { "rotation": -1, "vertical_offset": 70, "card_width": 280 } },
        { "type": "poster_card", "settings": { "rotation": 7, "vertical_offset": -8, "card_width": 260 } }
      ]
    }
  ]
}
{% endschema %}
