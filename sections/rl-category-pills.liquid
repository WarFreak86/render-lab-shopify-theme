<section class="rl-section rl-category-pills">
  <div class="rl-page-width">
    <h2>{{ section.settings.heading }}</h2>
    <div class="rl-category-pills__list">
      {% for block in section.blocks %}
        <a class="rl-pill" href="{{ block.settings.url }}" {{ block.shopify_attributes }}>
          <span>{{ block.settings.title }}</span>
          <b>{{ block.settings.icon }}</b>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Render-Lab category pills",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by obsession" }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Pill",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Gaming" },
        { "type": "text", "id": "icon", "label": "Icon text", "default": "*" },
        { "type": "url", "id": "url", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Render-Lab category pills",
      "blocks": [
        { "type": "pill", "settings": { "title": "All", "icon": "*" } },
        { "type": "pill", "settings": { "title": "Books", "icon": "+" } },
        { "type": "pill", "settings": { "title": "Space", "icon": "^" } },
        { "type": "pill", "settings": { "title": "Anime", "icon": "/" } },
        { "type": "pill", "settings": { "title": "Gaming", "icon": ">" } },
        { "type": "pill", "settings": { "title": "Movies", "icon": "#" } },
        { "type": "pill", "settings": { "title": "Nature", "icon": "~" } }
      ]
    }
  ]
}
{% endschema %}
