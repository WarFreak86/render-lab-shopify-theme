<section
  class="rl-collections-directory rl-page-width"
  style="
    --columns-desktop: {{ section.settings.columns_desktop }};
    --columns-mobile: {{ section.settings.columns_mobile }};
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <header class="rl-listing-head">
    <p class="rl-eyebrow">{{ section.settings.eyebrow }}</p>
    <h1>{{ section.settings.heading }}</h1>
    {% if section.settings.subheading != blank %}
      <div>{{ section.settings.subheading }}</div>
    {% endif %}
  </header>

  {% paginate collections by 48 %}
    <div class="rl-collection-card-grid">
      {% for collection in collections %}
        <a class="rl-collection-card" href="{{ collection.url }}">
          <div class="rl-collection-card__media rl-collection-card__media--{{ section.settings.image_ratio }}">
            {% if collection.image %}
              {{ collection.image | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 25vw, 50vw', alt: collection.title, class: 'rl-collection-card__image' }}
            {% elsif collection.products.first.featured_image %}
              {{ collection.products.first.featured_image | image_url: width: 900 | image_tag: loading: 'lazy', sizes: '(min-width: 990px) 25vw, 50vw', alt: collection.title, class: 'rl-collection-card__image' }}
            {% else %}
              <span class="rl-collection-card__placeholder"></span>
            {% endif %}
          </div>
          <div class="rl-collection-card__body">
            <h2>{{ collection.title }}</h2>
            {% if section.settings.show_description and collection.description != blank %}
              <p>{{ collection.description | strip_html | truncate: 120 }}</p>
            {% endif %}
            {% if section.settings.show_product_count %}
              <span>{{ collection.products_count }} designs</span>
            {% endif %}
          </div>
        </a>
      {% else %}
        <p class="rl-empty">No collections found.</p>
      {% endfor %}
    </div>

    {% if paginate.pages > 1 %}
      <nav class="rl-pagination" role="navigation">
        {{ paginate | default_pagination }}
      </nav>
    {% endif %}
  {% endpaginate %}
</section>

{% schema %}
{
  "name": "Collection directory",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Archive" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Explore collections" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Browse Render-Lab collections by style, drop, and visual world." },
    { "type": "range", "id": "columns_desktop", "label": "Columns desktop", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "range", "id": "columns_mobile", "label": "Columns mobile", "min": 1, "max": 2, "step": 1, "default": 1 },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" },
        { "value": "landscape", "label": "Landscape" }
      ],
      "default": "portrait"
    },
    { "type": "checkbox", "id": "show_description", "label": "Show collection description", "default": true },
    { "type": "checkbox", "id": "show_product_count", "label": "Show product count", "default": true },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 24, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 24, "max": 120, "step": 4, "unit": "px", "default": 72 }
  ]
}
{% endschema %}
