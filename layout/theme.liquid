<!doctype html>
<html class="rl-theme" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="#10111a">
    <title>{{ page_title }}{% if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>
    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}
    {{ content_for_header }}
    <style>
      :root {
        --rl-bg: {{ settings.background | default: '#10111a' }};
        --rl-panel: {{ settings.panel | default: '#171923' }};
        --rl-accent: {{ settings.accent | default: '#f2552c' }};
        --rl-button: {{ settings.button | default: '#ffffff' }};
      }
    </style>
    {{ 'render-lab.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'render-lab.js' | asset_url }}" defer></script>
  </head>
  <body class="template-{{ template.name | handle }}">
    <a class="skip-link" href="#MainContent">{{ 'accessibility.skip' | t }}</a>
    {% sections 'header-group' %}
    <main id="MainContent" role="main" tabindex="-1">
      {{ content_for_layout }}
    </main>
    {% sections 'footer-group' %}
    {% render 'cart-drawer' %}
  </body>
</html>
